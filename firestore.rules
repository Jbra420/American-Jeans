rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /products/{productId} {
      // Permitir leer a cualquiera para que los clientes vean el catálogo
      allow read: if true;
      
      // Permitir escribir a cualquiera temporalmente para pruebas.
      // NOTA DE SEGURIDAD: Una vez configurado en producción, se recomienda cambiar a:
      // allow write: if request.auth != null;
      allow write: if true;
    }
  }
}
